# Bez klíče níže → ukázková extrakce (8 řádků).
#
# Varianta A — OpenAI (platform.openai.com)
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Varianta B — Google Gemini Vision (klíč zdarma: aistudio.google.com)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
#
# Oba klíče: při 429 jeden provider zkusí druhý (Gemini↔OpenAI). Výchozí provider: Gemini.
# Jen OpenAI: EXTRACTION_PROVIDER=openai
# EXTRACTION_PROVIDER=gemini

# Volitelně: true = vždy jen ukázka | false = vždy API | nevyplněno = viz výše
# LEAFLET_PARSE_MOCK=

# Supabase (admin + shopper runtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
# DATABASE_URL= (optional fallback alias)
